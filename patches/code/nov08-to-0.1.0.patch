+
+#define SSE2_S0_S1(r, a, b, c)  \
+    AS2(    movq    mm6, r)\
+    AS2(    psrlq   r, a)\
+    AS2(    movq    mm7, r)\
+    AS2(    psllq   mm6, 64-c)\
+    AS2(    pxor    mm7, mm6)\
+    AS2(    psrlq   r, b-a)\
+    AS2(    pxor    mm7, r)\
+    AS2(    psllq   mm6, c-b)\
+    AS2(    pxor    mm7, mm6)\
+    AS2(    psrlq   r, c-b)\
+    AS2(    pxor    r, mm7)\
+    AS2(    psllq   mm6, b-a)\
+    AS2(    pxor    r, mm6)
