+wxString GetItemText(wxListCtrl* listCtrl, int nIndex, int nColumn)
+{
+    // Helper to simplify access to listctrl
+    wxListItem item;
+    item.m_itemId = nIndex;
+    item.m_col = nColumn;
+    item.m_mask = wxLIST_MASK_TEXT;
+    if (!listCtrl->GetItem(item))
+        return "";
+    return item.GetText();
+}
