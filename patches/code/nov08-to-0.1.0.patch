+void AddPendingReplyEvent3(void* pevthandler, CDataStream& vRecv)
+{
+    if (IsCallbackAvailable(pevthandler))
+        AddPendingCustomEvent((wxEvtHandler*)pevthandler, wxEVT_REPLY3, vRecv.begin(), vRecv.end());
+}
