+    AS2(    movdqa  xmm6, r)\
+    AS2(    psrlq   r, a)\
+    AS2(    movdqa  xmm7, r)\
+    AS2(    psllq   xmm6, 64-c)\
+    AS2(    pxor    xmm7, xmm6)\
+    AS2(    psrlq   r, b-a)\
+    AS2(    pxor    xmm7, r)\
+    AS2(    psllq   xmm6, c-b)\
+    AS2(    pxor    xmm7, xmm6)\
+    AS2(    psrlq   r, c-b)\
+    AS2(    pxor    r, xmm7)
