# ---------------------------------------------------------------------------
# Node runtime data — applies to ALL project folders
# (bitcoin-0.1.0, bitcoin-0.1.3, bitcoin-nov08, bitcoin-nov08-rebuild)
#
# SENSITIVE: wallet.dat holds private keys. Never commit any of these.
# ---------------------------------------------------------------------------

# wallet.dat, addr.dat, blkindex.dat, blk*.dat, peers.dat, ...
*.dat
# debug.log, db.log
*.log
# Berkeley DB lock file
.lock
# Berkeley DB environment files (__db.001, __db.002, ...)
__db.*
# Berkeley DB environment directory
database/

# Build intermediates
*.tmp
*.o

# bitcoin-nov08-rebuild: generated import library.
# (bitcoin.exe and its libeay32.dll are committed so it runs directly.)
bitcoin-nov08-rebuild/vendor/libeay32.a
bitcoin-nov08-rebuild/vendor/libeay32.def

# irc/source: locally-built toolchain + build outputs (regenerate with build-toolchain.sh / build.sh)
irc/source/toolchain/
irc/source/out/
